---
// src/components/Contact.astro
---

<section id="contact" class="bg-canvas-soft-2 border-b border-hairline py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Column: Contact Details & Info -->
      <div class="lg:col-span-5 flex flex-col justify-between">
        <div>
          <span class="font-mono text-[10px] uppercase tracking-wider text-link mb-3 inline-block">
            GET IN TOUCH
          </span>
          <h2 class="font-sans text-2xl md:text-3xl lg:text-[36px] font-semibold tracking-tight text-ink mb-6" style="letter-spacing: -1.2px;">
            Let’s discuss your requirements.
          </h2>
          <p class="font-sans text-sm md:text-base text-body leading-relaxed mb-8">
            Our offices are situated at the heart of Indore's business corridor. Speak with our experts to find the right hiring solution or career opportunity today.
          </p>

          <!-- Contact Details -->
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded bg-canvas border border-hairline flex items-center justify-center text-ink shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <h4 class="font-sans text-xs font-semibold text-ink uppercase tracking-wider mb-1">Corporate Office</h4>
                <p class="font-sans text-xs text-body leading-relaxed">
                  11/1 Rishi Market, A.B. Road,<br />
                  Opposite Palasia Police Station,<br />
                  Indore, Madhya Pradesh - 452001
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded bg-canvas border border-hairline flex items-center justify-center text-ink shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-1.514 2.02a13.717 13.717 0 0 1-5.905-5.905l2.02-1.514c.362-.272.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </div>
              <div>
                <h4 class="font-sans text-xs font-semibold text-ink uppercase tracking-wider mb-1">Direct Contact</h4>
                <p class="font-mono text-xs text-body">
                  Landline: <a href="tel:+917314225717" class="text-link hover:underline">0731-4225717</a>
                </p>
                <p class="font-mono text-xs text-body">
                  Mobile: <a href="tel:+919111143932" class="text-link hover:underline">+91 91111 43932</a>
                </p>
                <p class="font-mono text-xs text-body">
                  Email: <a href="mailto:bsjob123@gmail.com" class="text-link hover:underline">bsjob123@gmail.com</a>
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Simulated Map Component -->
        <div class="mt-8 lg:mt-0 w-full bg-canvas rounded border border-hairline p-4 shadow-xs relative overflow-hidden group">
          <div class="absolute inset-0 bg-canvas-soft-2 z-0 flex items-center justify-center pointer-events-none opacity-50">
            <!-- Simulated grid map overlay -->
            <div class="absolute inset-0" style="background-image: linear-gradient(rgba(23,23,23,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(23,23,23,0.03) 1px, transparent 1px); background-size: 20px 20px;"></div>
          </div>
          <div class="relative z-10 flex flex-col justify-between h-32">
            <div class="flex items-start justify-between">
              <div>
                <h5 class="font-sans text-[11px] font-semibold text-ink">Palasia Crossing Region</h5>
                <p class="font-sans text-[10px] text-mute">Opp. Palasia Police Station, Indore</p>
              </div>
              <span class="bg-cyan-soft text-cyan-deep font-mono text-[8px] uppercase tracking-wider px-1.5 py-0.5 rounded-full font-semibold border border-cyan-deep/10">Active Hub</span>
            </div>
            
            <a href="https://maps.app.goo.gl/S5fo9rqKq1rb4LeX7" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 font-sans text-[11px] text-link font-medium hover:text-link-deep transition-colors mt-auto w-fit">
              View on Google Maps
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3 transform group-hover:translate-x-0.5 transition-transform">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right Column: Interactive Contact Form -->
      <div class="lg:col-span-7">
        <div class="w-full bg-canvas border border-hairline rounded-md p-8 shadow-xs">
          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block font-sans text-xs font-medium text-body mb-2">Full Name</label>
                <input type="text" id="name" name="name" required placeholder="eg. Amit Sharma" class="w-full bg-canvas text-ink border border-hairline rounded focus:outline-none focus:border-hairline-strong px-4 text-xs h-10 transition-colors" />
              </div>
              <div>
                <label for="email" class="block font-sans text-xs font-medium text-body mb-2">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="eg. amit@example.com" class="w-full bg-canvas text-ink border border-hairline rounded focus:outline-none focus:border-hairline-strong px-4 text-xs h-10 transition-colors" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="phone" class="block font-sans text-xs font-medium text-body mb-2">Mobile Number</label>
                <input type="tel" id="phone" name="phone" required placeholder="eg. +91 98765 43210" class="w-full bg-canvas text-ink border border-hairline rounded focus:outline-none focus:border-hairline-strong px-4 text-xs h-10 transition-colors" />
              </div>
              <div>
                <label for="subject" class="block font-sans text-xs font-medium text-body mb-2">I am looking for</label>
                <select id="subject" name="subject" class="w-full bg-canvas text-ink border border-hairline rounded focus:outline-none focus:border-hairline-strong px-3 text-xs h-10 transition-colors cursor-pointer">
                  <option value="job">Career Opportunities (Job Seeker)</option>
                  <option value="hire">Talent Sourcing (Employer)</option>
                  <option value="consulting">Career Consulting</option>
                  <option value="other">General Queries</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block font-sans text-xs font-medium text-body mb-2">Detail Your Message</label>
              <textarea id="message" name="message" rows="4" required placeholder="Share details about your profile or company recruitment requirements..." class="w-full bg-canvas text-ink border border-hairline rounded focus:outline-none focus:border-hairline-strong p-4 text-xs transition-colors resize-none"></textarea>
            </div>

            <button type="submit" id="form-submit-btn" class="w-full bg-primary text-on-primary font-sans text-xs font-semibold py-3 rounded-full hover:bg-black transition-all active:scale-[0.99] flex items-center justify-center gap-2 cursor-pointer border border-transparent">
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>
            </button>
          </form>

          <!-- Form Success State (Hidden by default) -->
          <div id="form-success" class="hidden text-center py-8">
            <div class="w-12 h-12 rounded-full bg-cyan-soft text-cyan-deep flex items-center justify-center mx-auto mb-4 border border-cyan-deep/15">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            </div>
            <h3 class="font-sans text-base font-semibold text-ink mb-1">Message Sent.</h3>
            <p class="font-sans text-xs text-body max-w-sm mx-auto leading-relaxed">
              Thank you for reaching out. Bharat Kumar and the recruitment team at BS JOB Consultants will review your submission and contact you shortly.
            </p>
            <button id="form-reset-btn" class="mt-6 font-sans text-xs text-link font-medium hover:text-link-deep underline cursor-pointer bg-transparent border-0">
              Send another message
            </button>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('form-submit-btn');
  const successState = document.getElementById('form-success');
  const resetBtn = document.getElementById('form-reset-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    if (submitBtn) {
      // Show loading spinner
      submitBtn.innerHTML = `
        <svg class="animate-spin -ml-1 mr-3 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Sending...
      `;
      (submitBtn as HTMLButtonElement).disabled = true;
    }

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("https://formsubmit.co/ajax/bsjob123@gmail.com", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify({
          ...data,
          _subject: `Manpower/Manpower Inquiry (from ${data.name})`,
          _captcha: "false"
        })
      });

      if (response.ok) {
        form.classList.add('hidden');
        successState?.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error("Form submission endpoint returned error status.");
      }
    } catch (error) {
      console.error(error);
      alert("Submission error. Please send your inquiry directly to bsjob123@gmail.com.");
      if (submitBtn) {
        submitBtn.innerHTML = `
          Send Message
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
          </svg>
        `;
        (submitBtn as HTMLButtonElement).disabled = false;
      }
    }
  });

  resetBtn?.addEventListener('click', () => {
    successState?.classList.add('hidden');
    form?.classList.remove('hidden');
    if (submitBtn) {
      submitBtn.innerHTML = `
        Send Message
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      `;
      (submitBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>
