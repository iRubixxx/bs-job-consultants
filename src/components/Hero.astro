---
// src/components/Hero.astro
---

<section id="home" class="relative overflow-hidden bg-canvas-soft border-b border-hairline py-20 md:py-28 flex flex-col items-center justify-center text-center">
  <!-- Mesh Gradient Background -->
  <div class="absolute inset-0 z-0 opacity-40 pointer-events-none">
    <div class="absolute w-[600px] h-[600px] rounded-full blur-[140px] top-[-150px] left-[5%]" style="background: radial-gradient(circle, rgba(0,124,240,0.15) 0%, transparent 70%);"></div>
    <div class="absolute w-[600px] h-[600px] rounded-full blur-[140px] top-[-100px] right-[10%]" style="background: radial-gradient(circle, rgba(121,40,202,0.15) 0%, transparent 70%);"></div>
    <div class="absolute w-[600px] h-[600px] rounded-full blur-[140px] bottom-[-150px] left-[30%]" style="background: radial-gradient(circle, rgba(255,77,77,0.1) 0%, transparent 70%);"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 flex flex-col items-center">
    <!-- Eyebrow Banner -->
    <a href="#about" class="inline-flex items-center gap-2 bg-canvas border border-hairline hover:border-hairline-strong shadow-xs rounded-full px-3.5 py-1 mb-8 transition-all hover:scale-[1.01] active:scale-100">
      <span class="font-mono text-[10px] uppercase tracking-wider text-body flex items-center gap-1.5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyan-deep animate-pulse"></span>
        Indore Placement Leader
      </span>
      <span class="inline-block w-px h-3 bg-hairline"></span>
      <span class="font-sans text-[11px] font-semibold text-link hover:text-link-deep flex items-center gap-0.5">
        Meet Founder Bharat Kumar
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </span>
    </a>

    <!-- Headline (display-xl) -->
    <h1 class="font-sans text-3xl sm:text-4xl md:text-5xl lg:text-[52px] font-semibold tracking-tight text-ink leading-tight max-w-3xl mb-6 select-none" style="letter-spacing: -2px;">
      Connecting exceptional talent with industry leaders.
    </h1>

    <!-- Subheading (body-lg) -->
    <p class="font-sans text-base md:text-lg text-body max-w-2xl mb-8 leading-relaxed">
      BS JOB Consultants is Indore's premier recruitment consultancy. For over a decade, we have partnered with India’s leading enterprises to build outstanding teams while guiding job seekers toward their career potential.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
      <a href="#services" class="button-primary w-full sm:w-auto text-center font-sans text-sm font-medium py-3 px-8 cursor-pointer">
        Explore Services
      </a>
      <a href="#contact" class="button-secondary w-full sm:w-auto text-center font-sans text-sm font-medium py-3 px-8 cursor-pointer">
        Schedule Consultation
      </a>
    </div>
  </div>
</section>
