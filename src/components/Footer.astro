---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-canvas border-t border-hairline py-16 md:py-20 text-body">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12">
      
      <!-- Brand column -->
      <div class="space-y-4">
        <a href="#home" class="flex items-center gap-2.5">
          <div class="w-7 h-7 rounded bg-primary flex items-center justify-center text-on-primary font-mono text-xs font-semibold tracking-tighter">
            BS
          </div>
          <span class="font-sans font-semibold text-[14px] tracking-tight text-ink">BS JOB Consultants</span>
        </a>
        <p class="font-sans text-xs text-body leading-relaxed max-w-xs">
          Connecting top corporate talent with industry leaders in Indore, Madhya Pradesh, and across India since 2008.
        </p>
        <p class="font-mono text-[10px] text-mute mt-4">
          &copy; {year} BS JOB Consultants.<br />All rights reserved.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-mono text-[9px] uppercase tracking-wider text-ink font-semibold mb-4">Navigation</h4>
        <ul class="space-y-2.5 font-sans text-xs">
          <li>
            <a href="#home" class="hover:text-ink transition-colors">Home</a>
          </li>
          <li>
            <a href="#about" class="hover:text-ink transition-colors">About Us</a>
          </li>
          <li>
            <a href="#services" class="hover:text-ink transition-colors">Services</a>
          </li>
          <li>
            <a href="#contact" class="hover:text-ink transition-colors">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-mono text-[9px] uppercase tracking-wider text-ink font-semibold mb-4">Contact</h4>
        <ul class="space-y-2.5 font-sans text-xs">
          <li class="leading-relaxed">
            11/1 Rishi Market, A.B. Road,<br />
            Opp. Palasia Police Station,<br />
            Indore, MP - 452001
          </li>
          <li>
            Phone: <a href="tel:+917314225717" class="text-link hover:text-link-deep transition-colors">0731-4225717</a>
          </li>
          <li class="text-mute font-mono text-[9px] uppercase tracking-wider mt-2">
            Hours: 10:00 AM - 6:30 PM
          </li>
        </ul>
      </div>

      <!-- Trust & Anti-Fraud Disclaimer -->
      <div>
        <h4 class="font-mono text-[9px] uppercase tracking-wider text-ink font-semibold mb-4">Candidate Safety</h4>
        <div class="bg-canvas-soft p-4 border border-hairline rounded space-y-2 shadow-xs">
          <div class="flex items-center gap-1.5 text-warning-deep">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <span class="font-sans text-[9px] font-semibold uppercase tracking-wider">Zero Registration Fee</span>
          </div>
          <p class="font-sans text-[10px] text-body leading-relaxed">
            BS JOB Consultants does not charge any registration fees or placement deposits from candidates. We recommend verifying any interview call directly with our office.
          </p>
        </div>
      </div>

    </div>

    <!-- Bottom developer credit -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-12 pt-8 border-t border-hairline font-sans text-[10px] text-mute">
      <div>
        <span>Founded by Bharat Kumar</span>
      </div>
      <div>
        <span class="flex items-center gap-1">
          Designed in compliance with
          <a href="#" class="font-mono hover:text-ink hover:underline">DESIGN.md</a>
        </span>
      </div>
    </div>
  </div>
</footer>
