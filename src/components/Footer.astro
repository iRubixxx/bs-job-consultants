---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-canvas border-t border-hairline py-16 md:py-20 text-body">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      
      <!-- Brand column -->
      <div class="space-y-4">
        <a href="#home" class="flex items-center gap-2.5">
          <img src="/logo.png" alt="BS JOB Consultants Logo" class="w-7 h-7 object-contain" />
          <span class="font-sans font-semibold text-[14px] tracking-tight text-ink">BS JOB Consultants</span>
        </a>
        <p class="font-sans text-xs text-body leading-relaxed max-w-xs">
          Connecting top corporate talent with industry leaders in Indore, Madhya Pradesh, and across India since 2008.
        </p>
        <p class="font-mono text-[10px] text-mute mt-4">
          &copy; {year} BS JOB Consultants.<br />All rights reserved.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-mono text-[9px] uppercase tracking-wider text-ink font-semibold mb-4">Navigation</h4>
        <ul class="space-y-2.5 font-sans text-xs">
          <li>
            <a href="#home" class="hover:text-ink transition-colors">Home</a>
          </li>
          <li>
            <a href="#about" class="hover:text-ink transition-colors">About Us</a>
          </li>
          <li>
            <a href="#industries" class="hover:text-ink transition-colors">Industries</a>
          </li>
          <li>
            <a href="#services" class="hover:text-ink transition-colors">Services</a>
          </li>
          <li>
            <a href="#contact" class="hover:text-ink transition-colors">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-mono text-[9px] uppercase tracking-wider text-ink font-semibold mb-4">Contact</h4>
        <ul class="space-y-2.5 font-sans text-xs">
          <li class="leading-relaxed">
            11/1 Rishi Market, A.B. Road,<br />
            Opp. Palasia Police Station,<br />
            Indore, MP - 452001
          </li>
          <li>
            Phone: <a href="tel:+917314225717" class="text-link hover:text-link-deep transition-colors">0731-4225717</a>
          </li>
          <li>
            Mobile: <a href="tel:+919111143932" class="text-link hover:text-link-deep transition-colors">+91 91111 43932</a>
          </li>
          <li>
            Email: <a href="mailto:bsjob123@gmail.com" class="text-link hover:text-link-deep transition-colors">bsjob123@gmail.com</a>
          </li>
          <li class="text-mute font-mono text-[9px] uppercase tracking-wider mt-2">
            Hours: 10:00 AM - 6:30 PM
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom developer credit -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-12 pt-8 border-t border-hairline font-sans text-[10px] text-mute">
      <div>
        <span>Founded by Bharat Kumar</span>
      </div>
    </div>
  </div>
</footer>
