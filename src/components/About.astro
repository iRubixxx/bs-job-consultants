---
// src/components/About.astro
---

<section id="about" class="bg-canvas-soft border-b border-hairline py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left Column: Legacy & Vision -->
      <div class="lg:col-span-7 flex flex-col justify-center">
        <span class="font-mono text-[10px] uppercase tracking-wider text-link mb-3 inline-block">
          WHO WE ARE
        </span>
        <h2 class="font-sans text-2xl md:text-3xl lg:text-[36px] font-semibold tracking-tight text-ink leading-tight mb-6" style="letter-spacing: -1.2px;">
          Indore’s trusted recruitment specialists since 2008.
        </h2>
        <div class="space-y-4 font-sans text-sm md:text-[15px] text-body leading-relaxed">
          <p>
            BS JOB Consultants was established with a singular mission: to connect Indore's rising talent pool with industry-leading corporations across India. Over the years, we have evolved into a premier recruitment and manpower consultancy, trusted by blue-chip enterprises and energetic startups alike.
          </p>
          <p>
            Operating from the commercial hub of Madhya Pradesh, we offer a comprehensive suite of placement, executive search, and career consulting services. Our approach is deeply local yet structured globally—understanding the specific operational realities of regional industries while maintaining world-class sourcing standards.
          </p>
        </div>
      </div>

      <!-- Right Column: Founder Profile Card -->
      <div class="lg:col-span-5 flex items-center justify-center">
        <div class="w-full card-marketing bg-canvas relative p-8">
          <div class="absolute -top-3 left-6 bg-primary text-on-primary font-mono text-[9px] uppercase tracking-widest px-2.5 py-1 rounded-xs">
            Founder Profile
          </div>
          
          <div class="mt-4">
            <!-- Icon/Visual Placeholder -->
            <div class="w-12 h-12 rounded-full bg-canvas-soft-2 flex items-center justify-center border border-hairline mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-ink">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </div>
            
            <h3 class="font-sans text-lg font-semibold text-ink mb-1">
              Bharat Kumar
            </h3>
            <p class="font-mono text-[10px] text-mute uppercase tracking-wider mb-4">
              Founder & Managing Director
            </p>
            
            <blockquote class="border-l-2 border-hairline-strong pl-4 my-6 font-sans italic text-sm text-body leading-relaxed">
              "Our strength lies in our relationships. We don't just fill job positions; we build the human infrastructure that drives business success and shapes career trajectories."
            </blockquote>
            
            <div class="flex items-center gap-3 mt-6 pt-6 border-t border-hairline">
              <span class="font-sans text-xs text-mute">Serving Indore & National Markets</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
