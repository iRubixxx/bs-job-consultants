---
// src/components/LogoStrip.astro
---

<div class="w-full bg-canvas border-b border-hairline py-8">
  <div class="max-w-6xl mx-auto px-6">
    <p class="text-center font-mono text-[9px] uppercase tracking-widest text-mute mb-5">
      Sectors & Industries We Partner With
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6 items-center justify-items-center opacity-80">
      <!-- IT & Tech -->
      <div class="flex items-center gap-2 text-body hover:text-ink transition-colors cursor-default">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-mute">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
        </svg>
        <span class="font-sans font-semibold text-xs tracking-tight">IT & Tech</span>
      </div>

      <!-- Manufacturing -->
      <div class="flex items-center gap-2 text-body hover:text-ink transition-colors cursor-default">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-mute">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-5 0a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" />
        </svg>
        <span class="font-sans font-semibold text-xs tracking-tight">Manufacturing</span>
      </div>

      <!-- Banking & Finance -->
      <div class="flex items-center gap-2 text-body hover:text-ink transition-colors cursor-default">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-mute">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.5M4.5 21V10.5M3 21h18M12 6.75h.008v.008H12V6.75Z" />
        </svg>
        <span class="font-sans font-semibold text-xs tracking-tight">Banking & Finance</span>
      </div>

      <!-- Engineering -->
      <div class="flex items-center gap-2 text-body hover:text-ink transition-colors cursor-default">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-mute">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.096 9.31 17.207a2.25 2.25 0 1 1-3.182-3.182l2.11-2.113m3.182 3.182a2.25 2.25 0 0 0 3.181-3.182l-2.11-2.113m-3.182 3.182a2.25 2.25 0 0 1-3.182-3.182l2.11-2.113m3.182 3.182 2.11-2.113a2.25 2.25 0 1 1 3.182 3.182l-2.11 2.113m-3.182-3.182V9a1.5 1.5 0 0 0-1.5-1.5H9m3 3V15m0-3h3" />
        </svg>
        <span class="font-sans font-semibold text-xs tracking-tight">Engineering</span>
      </div>

      <!-- Healthcare -->
      <div class="flex items-center gap-2 text-body hover:text-ink transition-colors cursor-default">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-mute">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        <span class="font-sans font-semibold text-xs tracking-tight">Healthcare</span>
      </div>
    </div>
  </div>
</div>
