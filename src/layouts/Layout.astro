---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "BS JOB Consultants | Premium Recruitment & Job Placement Indore", 
	description = "BS JOB Consultants is Indore's premier career placement and corporate recruitment firm. Founded by Bharat Kumar, we connect top talent with industry leaders." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="BS Job Consultants, BS JOB Consultants Indore, recruitment agency Indore, placement consultancy Indore, job placement Indore, Bharat Kumar, manpower placement Indore, hiring agencies Indore" />
		
		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-canvas-soft text-ink font-sans antialiased min-h-screen flex flex-col selection:bg-primary selection:text-on-primary">
		<slot />
	</body>
</html>
